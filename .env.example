# PostgreSQL connection string (Railway provides this when you add a Postgres service)
DATABASE_URL="postgresql://user:password@localhost:5432/bookmaker"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me"

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-..."
# Any OpenRouter model slug; flagship default below
OPENROUTER_MODEL="anthropic/claude-sonnet-4.5"

# Public URL of the deployed app (used for OpenRouter attribution headers)
APP_URL="http://localhost:3000"

# Where uploaded images are stored. On Railway, attach a volume and point this at its mount path (e.g. /data/uploads)
UPLOAD_DIR=""
